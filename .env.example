SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_smtp_username
SMTP_PASSWORD=your_smtp_password
SENDER_EMAIL=alerts@example.com
RECIPIENT_EMAIL=security-team@example.com

DATABASE_URL=postgresql+psycopg2://cyber_news:cyber_news@postgres:5432/cyber_news

LOG_LEVEL=INFO
REQUEST_TIMEOUT_SECONDS=15
MAX_ARTICLES_PER_SOURCE=50
ENABLE_GDELT=true
GDELT_QUERY_WINDOW_MINUTES=180

# Comma-separated list or JSON array format
RSS_FEEDS=https://krebsonsecurity.com/feed/,https://www.bleepingcomputer.com/feed/,https://therecord.media/feed/
GOOGLE_NEWS_QUERIES=["phishing attack company OR government OR university OR hospital","business email compromise attack organization","malvertising attack victim"]
